# Copy this file to .env and set secure values before starting docker compose.

# Generate with: openssl rand -hex 32
API_JWT_SECRET=replace-with-long-random-secret

# Generate with: openssl rand -hex 32
# Used by docker compose services AND by local dev tools (map_viewer,
# template_viewer, dat-to-keydb) when MAG_KEYDB_URL is not set.
# After copying this file: source .env  — then run local tools normally.
KEYDB_PASSWORD=replace-with-long-random-password

# Optional: set this to override the full KeyDB URL used by local tools.
# If unset, tools derive the URL from KEYDB_PASSWORD above.
# MAG_KEYDB_URL=redis://:replace-with-long-random-password@127.0.0.1:5556/
