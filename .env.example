# Copy this file to .env and set secure values before starting docker compose.

# Generate with: openssl rand -hex 32
API_JWT_SECRET=replace-with-long-random-secret

# Generate with: openssl rand -hex 32
# Used by docker compose services AND by local dev tools (map_viewer,
# template_viewer, world-snapshot) when MAG_KEYDB_URL is not set.
# After copying this file: source .env  — then run local tools normally.
KEYDB_PASSWORD=replace-with-long-random-password

# Optional: set this to override the full KeyDB URL used by local tools.
# If unset, tools derive the URL from KEYDB_PASSWORD above.
# MAG_KEYDB_URL=redis://:replace-with-long-random-password@127.0.0.1:5556/

# Optional: enable the admin template-editing API surface.
# Generate with: openssl rand -hex 32 (must be at least 32 bytes / 64 hex chars).
# When unset, /admin/* routes are not mounted and the server reload watcher
# becomes a no-op. Required for use of `template_viewer --api ...`.
# MAG_ADMIN_API_TOKEN=replace-with-long-random-admin-token

# Optional: disable the server-side template reload watcher even if the
# admin token is set (for emergency lockdown / debugging).
# MAG_ADMIN_RELOAD_DISABLED=1

MAG_GOD_PASSWORD=devpassword